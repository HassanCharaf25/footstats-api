# =============================================================
# FootStats API - Variables d'environnement (exemple)
# Copie ce fichier en `.env` et adapte les valeurs si besoin.
# =============================================================

# --- MySQL (utilisé par le conteneur db) ---
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=footstats
MYSQL_USER=footuser
MYSQL_PASSWORD=footpass

# --- Connexion API -> base ---
# Le hôte "db" correspond au nom du service dans docker-compose.yml
DATABASE_URL=mysql+pymysql://footuser:footpass@db:3306/footstats

# --- Flask ---
FLASK_ENV=development
FLASK_APP=wsgi.py
SECRET_KEY=change-me-in-production

# --- Port exposé par l'API ---
API_PORT=5000
